generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// PostgreSQL (Docker locally, Railway Postgres in production).
// Legacy SQLite can be migrated via: npm run migrate:sqlite-to-pg
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite (via Prisma) does not support native enums or scalar lists.
// - "enum" fields are stored as String (allowed values documented in code,
//   see src/shared/enums.ts).
// - list fields are stored as JSON-encoded String (parsed in guild-config).

// ---------------------------------------------------------------------------
// Per-guild configuration. One row per Discord server.
// ---------------------------------------------------------------------------
model Guild {
  id           String  @id // Discord guild id
  prefix       String  @default("!")
  noPrefixMode Boolean @default(false)

  // Setup state
  setupDone   Boolean @default(false)
  logCategory String?
  modCategory String?

  // System role ids created during setup
  mutedRoleId        String?
  prisonRoleId       String?
  vmuteRoleId        String?
  newRoleId          String?
  unverifiedRoleId   String?
  blacklistedRoleId  String?

  // Special / decorative roles (also auto-created on setup)
  picRoleId   String?
  hereRoleId  String?
  liveRoleId  String?
  autoRoleIds String  @default("[]") // JSON string[]

  // Restricted category + channels (black / prison)
  restrictedCategoryId String?
  blackChannelId       String?
  blackVoiceId         String?
  prisonChannelId      String?
  prisonVoiceId        String?

  // When true, deny pic/here/live on @everyone guild-wide
  decorBaselineEnabled Boolean @default(true)

  // Channels used by member-gating systems
  newChannelId    String?
  verifyChannelId String?

  // Unified text channel for admin coordination (voice-move consent, etc.)
  adminLoungeChannelId String?

  // Logging mode: "DETAILED" | "COMPACT"
  logMode String @default("DETAILED")

  // New-account gating (the "new" system)
  newEnabled    Boolean @default(false)
  newMinAgeDays Int     @default(0)
  newMessage    String?

  // Verification
  verifyEnabled           Boolean @default(false)
  verifyMessage           String?
  verifiedRoleId          String?
  verifyReactionEnabled   Boolean @default(false)
  verifyReactionMessageId String?
  verifyReactionEmoji     String?

  // antijoin action for brand new accounts: "NONE" | "BAN" | "PRISON" | "KICK"
  antijoinEnabled    Boolean @default(false)
  antijoinAction     String  @default("NONE")
  antijoinMinAgeDays Int     @default(0)

  // Moderation settings
  banMessage      String?
  punishOnlyAdmin Boolean @default(false) // only the punisher (or owners) can lift
  reasons         String  @default("[]") // legacy JSON string[] (migrated to punishReasons)
  punishReasons   String  @default("[]") // JSON PunishReason[]

  // Protection toggles
  antiDelete      Boolean @default(false)
  antiLinks       Boolean @default(false)
  antiPerms       Boolean @default(false)
  antiBots        Boolean @default(false)
  antiWord        Boolean @default(false)
  bannedWords     String  @default("[]") // JSON string[]
  protectionLimit Int     @default(3)

  // Spam limits
  spamEnabled  Boolean @default(false)
  spamMessages Int     @default(5)
  spamSeconds  Int     @default(5)

  // Auto chat features
  autoLine   Boolean @default(false)
  autoClear  Boolean @default(false)
  autoReact  Boolean @default(false)
  reactEmoji String?
  embedColor String  @default("#5865F2")
  embedPic   String?

  // Invites / link
  linkInfo String?

  // Relations
  logChannels     GuildLogChannel[]
  owners          BotOwner[]
  accessEntries   AccessEntry[]
  commandConfigs  CommandConfig[]
  penalties       Penalty[]
  warns           Warn[]
  points          Point[]
  trustEntries    TrustEntry[]
  blacklistChats  BlacklistChat[]
  channelDenies   ChannelDeny[]
  specialRoles    SpecialRole[]
  reactionRoles   ReactionRole[]
  tasks           ModTask[]
  exemptions      Exemption[]
  punishPerms     PunishPerm[]
  antiCollections AntiCollection[]
  commandAliases  CommandAlias[]
  interactiveRoles   InteractiveRole[]
  adminRoles         AdminRole[]
  channelStressStates ChannelStressState[]
  channelAutoFeatures ChannelAutoFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-channel spam stress / autoLine suspension (survives restarts).
model ChannelStressState {
  id                     String    @id @default(cuid())
  guild                  Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId                String
  channelId              String
  autoLineSuspendedUntil DateTime?
  lastConfidence         Float     @default(0)
  suspendCount           Int       @default(0)
  updatedAt              DateTime  @updatedAt

  @@unique([guildId, channelId])
  @@index([guildId])
}

// Per-channel auto line / react (setline, setreact, etc.).
model ChannelAutoFeature {
  id         String  @id @default(cuid())
  guild      Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId    String
  channelId  String
  autoLine   Boolean @default(false)
  autoReact  Boolean @default(false)
  reactEmoji String?

  @@unique([guildId, channelId])
  @@index([guildId])
}

// One channel per logged event type (detailed) or shared (compact).
model GuildLogChannel {
  id        String @id @default(cuid())
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  eventType String // e.g. "memberJoin", "messageDelete", "voiceMove"
  channelId String

  @@unique([guildId, eventType])
  @@index([guildId])
}

// Bot-level owners, independent from Discord ownership.
model BotOwner {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String

  @@unique([guildId, userId])
  @@index([guildId])
}

// allow / deny lists for command usage. Target can be a user or a role.
// type: "USER" | "ROLE"  |  mode: "ALLOW" | "DENY"
model AccessEntry {
  id       String @id @default(cuid())
  guild    Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId  String
  targetId String
  type     String
  mode     String

  @@unique([guildId, targetId, mode])
  @@index([guildId])
}

// Per-command enable/disable + required permission overrides (cmd command).
model CommandConfig {
  id             String  @id @default(cuid())
  guild          Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId        String
  commandName    String
  enabled        Boolean @default(true)
  allowedRoleIds String  @default("[]") // JSON string[]
  allowedUserIds String  @default("[]") // JSON string[]

  @@unique([guildId, commandName])
  @@index([guildId])
}

// Active and historical penalties (mute, prison, vmute, ban, etc.).
// type: "MUTE" | "PRISON" | "VMUTE" | "BAN" | "BLACKLIST" | "BLOCK" | "WARN"
model Penalty {
  id          String    @id @default(cuid())
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId     String
  userId      String
  type        String
  moderatorId String
  reason      String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  liftedAt    DateTime?
  liftedById  String?

  @@index([guildId, userId])
  @@index([active, expiresAt])
}

model Warn {
  id          String   @id @default(cuid())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId     String
  userId      String
  moderatorId String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([guildId, userId])
}

model Point {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String
  amount  Int    @default(0)

  @@unique([guildId, userId])
  @@index([guildId])
}

model TrustEntry {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String

  @@unique([guildId, userId])
}

model BlacklistChat {
  id        String @id @default(cuid())
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  channelId String

  @@unique([guildId, channelId])
}

// Per-channel join allow/deny for voice channels (callow / cdeny).
// mode: "ALLOW" | "DENY"
model ChannelDeny {
  id        String @id @default(cuid())
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  channelId String
  userId    String
  mode      String

  @@unique([guildId, channelId, userId])
  @@index([guildId])
}

// Per-member personal roles (srole / myrole / color).
model SpecialRole {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  ownerId String
  roleId  String

  @@unique([guildId, ownerId])
}

model ReactionRole {
  id        String @id @default(cuid())
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  messageId String
  emoji     String
  roleId    String

  @@unique([guildId, messageId, emoji])
}

model ModTask {
  id        String   @id @default(cuid())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  userId    String
  task      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([guildId, userId])
}

// An exemption shields a user from a given penalty type until removed.
model Exemption {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String
  type    String

  @@unique([guildId, userId, type])
}

// Who may lift punishments (pallow / plist).
model PunishPerm {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String

  @@unique([guildId, userId])
}

// Per-guild custom command aliases (doadd / dochange).
model CommandAlias {
  id          String  @id @default(cuid())
  guild       Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId     String
  commandName String
  alias       String
  isPrimary   Boolean @default(false)

  @@unique([guildId, alias])
  @@index([guildId, commandName])
}

// Anti-role collections (collection / ecollection): grouped settings as JSON.
model AntiCollection {
  id      String @id @default(cuid())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  name    String
  data    String @default("{}") // JSON object

  @@unique([guildId, name])
}

// Per-role interactive permissions (pic/here/live/mute/deafen/admin commands).
model InteractiveRole {
  id              String  @id @default(cuid())
  guild           Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId         String
  roleId          String
  sortOrder       Int     @default(0)
  attachFiles     Boolean @default(false)
  mentionEveryone Boolean @default(false)
  stream          Boolean @default(false)
  muteMembers     Boolean @default(false)
  deafenMembers   Boolean @default(false)
  allowedCommands String  @default("[]") // JSON string[]

  @@unique([guildId, roleId])
  @@index([guildId])
}

// Per-role admin command grants (configured via VIP admin-roles panel).
model AdminRole {
  id              String @id @default(cuid())
  guild           Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId         String
  roleId          String
  sortOrder       Int    @default(0)
  allowedCommands String @default("[]") // JSON string[]

  @@unique([guildId, roleId])
  @@index([guildId])
}
