# Discord bot token (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your_bot_token_here

# Default global owner IDs (comma separated Discord user IDs)
GLOBAL_OWNERS=123456789012345678

# Super developer — only this user can use sysctrl (silent ignore for everyone else)
DEVELOPER_ID=123456789012345678

# Default command prefix (can be changed per-guild via the setprefix command)
DEFAULT_PREFIX=!

# PostgreSQL (Docker Compose local)
DATABASE_URL=postgresql://sysbot:sysbot_local@localhost:5432/sysbot?schema=public

# Legacy SQLite path for one-time migration only:
# SQLITE_SOURCE_URL=file:../data/sysbot.db

# Command rate limit (per member per guild)
CMD_RATE_LIMIT_MAX=3
CMD_RATE_LIMIT_WINDOW_MS=5000

# Sharding: 0 = single process, 2+ = manual shard count
SHARD_COUNT=0

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "true" while developing to pretty-print logs (use "false" on Railway)
LOG_PRETTY=false
