# Discord bot token (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your_bot_token_here

# Default global owner IDs (comma separated Discord user IDs)
# These owners can manage the bot in every guild.
GLOBAL_OWNERS=123456789012345678

# Default command prefix (can be changed per-guild via the setprefix command)
DEFAULT_PREFIX=!

# Local SQLite database (resolves to <project>/data/sysbot.db).
# The path is relative to the prisma/ folder, so "../data" points to the
# project root for both the Prisma CLI and the runtime client.
# On Railway: attach a Volume mounted at /data and set DATABASE_URL=file:/data/sysbot.db
DATABASE_URL=file:../data/sysbot.db

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "true" while developing to pretty-print logs (use "false" on Railway)
LOG_PRETTY=false
